      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "RunCat Neo stellt allen Nutzern alle Funktionen kostenlos zur Verfügung.\nDu kannst dieses Projekt unterstützen, indem du eine heiße Schokolade spendierst."
