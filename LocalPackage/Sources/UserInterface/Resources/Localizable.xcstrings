    "metricsBarNotes" : {
      "comment" : "A description of the functionality of the metrics bar.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Wenn du ein MacBook mit Notch verwendest, ist die Metrikleiste in der Menüleiste möglicherweise nicht sichtbar oder andere Objekte in der Menüleiste sind eventuell nicht erreichbar."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "If you use MacBook with a notch, you may not be able to see the Metrics Bar on the menu bar or not be able to access other menu bar items."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si usas un MacBook con muesca, es posible que la barra de métricas no se vea en la barra de menús o que no puedas acceder a otros elementos de la barra de menús."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Si vous utilisez un MacBook avec encoche, la barre de métriques peut ne pas être visible dans la barre des menus, ou d’autres éléments de la barre des menus peuvent devenir inaccessibles."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ノッチ付きのMacBookを使用している場合、メニューバー上にメトリクスバーが表示できないことや、他のメニューバー上のアイテムにアクセスできなくなることがあります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "노치가 있는 MacBook을 사용하는 경우, 메뉴 막대에 메트릭 막대가 표시되지 않거나 메뉴 막대의 다른 항목에 접근할 수 없게 될 수 있습니다."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Если вы используете MacBook с вырезом, панель метрик может не отображаться в строке меню, либо другие элементы строки меню могут стать недоступными."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Nếu bạn dùng MacBook có phần khuyết, thanh số liệu có thể không hiển thị trên thanh menu hoặc bạn có thể không truy cập được các mục khác trên thanh menu."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你使用带刘海的 MacBook，菜单栏上可能无法显示指标栏，或者无法访问菜单栏上的其他项目。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "如果你使用帶瀏海的 MacBook，選單列上可能無法顯示指標列，或無法取用選單列上的其他項目。"
          }
        }
      }
    },
